# =============================================================================
# 楽天ROOM 自動投稿システム - 環境変数
# このファイルを .env としてコピーして、各値を埋めてください
#   $ cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# 楽天会員（投稿アカウント）
# -----------------------------------------------------------------------------
# 楽天IDログインに使うメールアドレス／パスワード
RAKUTEN_EMAIL=your-email@example.com
RAKUTEN_PASSWORD=your-password

# 楽天ROOM のユーザーID
# プロフィールURL末尾の文字列です: room.rakuten.co.jp/<ここがID>
ROOM_USER_ID=your_room_user_id

# -----------------------------------------------------------------------------
# 楽天ウェブサービス API
# 取得手順: https://webservice.rakuten.co.jp/
# 1. アプリID登録 → application ID と access key を取得
# 2. 楽天アフィリエイトIDも併せて控える
# -----------------------------------------------------------------------------
RAKUTEN_APP_ID=your_application_id
RAKUTEN_ACCESS_KEY=your_access_key
RAKUTEN_AFFILIATE_ID=your_affiliate_id
